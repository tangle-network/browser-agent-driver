{
  "name": "@tangle-network/agent-browser-driver",
  "version": "0.5.0",
  "description": "LLM-driven browser agent for UI automation, testing, and evaluation",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-driver": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth:save-state": "node ./scripts/save-storage-state.mjs",
    "skills:install": "node ./scripts/install-skills.mjs",
    "reliability:scorecard": "node ./scripts/reliability-scorecard.mjs",
    "baseline:modes": "node ./scripts/run-mode-baseline.mjs",
    "baseline:track": "node ./scripts/run-scenario-track.mjs",
    "bench:observe": "tsx bench/observe-bench.ts",
    "bench:agent": "tsx bench/agent-bench.ts"
  },
  "keywords": [
    "agent",
    "automation",
    "playwright",
    "llm",
    "testing",
    "browser",
    "accessibility",
    "a11y"
  ],
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/tangle-network/agent-browser-driver.git"
  },
  "homepage": "https://github.com/tangle-network/agent-browser-driver#readme",
  "bugs": {
    "url": "https://github.com/tangle-network/agent-browser-driver/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^3.0.49",
    "@ai-sdk/google": "^3.0.33",
    "playwright": "^1.40.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.36",
    "ai": "^6.0.104",
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.49",
    "@ai-sdk/google": "^3.0.33",
    "@types/node": "^20.10.0",
    "playwright": "^1.40.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
