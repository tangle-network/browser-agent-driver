{
  "name": "@tangle-network/agent-driver-app",
  "version": "0.1.0",
  "description": "Sandbox orchestration for distributing agent-browser-driver test suites across isolated environments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-sandbox": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test:setup": "node --loader ts-node/esm tests/setup.ts",
    "test:e2e": "node --loader ts-node/esm tests/run-e2e.ts",
    "test:smoke": "node --loader ts-node/esm tests/smoke.ts"
  },
  "license": "(MIT OR Apache-2.0)",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@tangle-network/agent-browser-driver": "file:../"
  },
  "peerDependencies": {
    "@tangle/sandbox": "^0.0.1"
  },
  "peerDependenciesMeta": {
    "@tangle/sandbox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tangle/sandbox": "file:../../agent-dev-container/products/sandbox/sdk",
    "@types/node": "^20.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  }
}
